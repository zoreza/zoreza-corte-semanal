# ── Zoreza Pro — Backend Environment ──────────────────────────────
# Copy this file to .env and adjust values for your environment.

# Database
DATABASE_URL=postgresql+asyncpg://zoreza:zoreza@localhost:5432/zoreza_pro

# JWT secret — generate with: openssl rand -hex 64
SECRET_KEY=cambiar-esta-clave-en-produccion-usar-openssl-rand-hex-64

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Timezone
APP_TZ=America/Mexico_City

# Debug mode (enable SQL echo + detailed errors)
DEBUG=false
